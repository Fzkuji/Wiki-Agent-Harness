{#- description: side-by-side comparison of 2+ options. Slots: summary, table, verdict. -#}
{% extends "base.html.j2" %}

{% block main %}
<article>
  <h1>{{ meta.get("title", "Untitled") }}</h1>

  <p class="lede">
    <!-- wah:slot id="summary" -->
    <!-- /wah:slot -->
  </p>

  <table>
    <!-- wah:slot id="table" -->
    <!-- fill with <thead><tr><th>X</th>...</tr></thead><tbody>... -->
    <!-- /wah:slot -->
  </table>

  <section>
    <h2>Verdict</h2>
    <!-- wah:slot id="verdict" -->
    <!-- /wah:slot -->
  </section>

  {%- if meta.get("related") %}
  <h2 class="section-label">Related</h2>
  <div class="card-grid">
    {%- for r in meta.get("related", []) %}
    <a href="{{ r.href }}" class="card"><h3>{{ r.title }}</h3></a>
    {%- endfor %}
  </div>
  {%- endif %}
</article>
{% endblock %}
