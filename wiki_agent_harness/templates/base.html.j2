{#- Shared shell — Tailwind + daisyUI via CDN.

Always-loaded:
  * Tailwind CSS (Play CDN)        — utility classes
  * daisyUI v5                      — pre-built components + themes
  * Inter + JetBrains Mono          — typography

Lazy-loaded only when content uses them:
  * highlight.js  — <pre><code class="language-…">
  * Mermaid       — <pre class="mermaid">
  * KaTeX         — $math$ / $$math$$ / .math
  * Chart.js      — <canvas data-chart="…">
  * Lucide icons  — <i data-lucide="name"></i>
  * glightbox     — .zoomable

Tailwind + daisyUI rationale: any open-source page using Tailwind
(shadcn/ui, Vercel templates, Flowbite, Preline, HyperUI, Tailblocks,
daisyUI examples, etc.) can be copy-pasted directly into a slot.
-#}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<!-- Tailwind v3 Play CDN with daisyUI plugin -->
<link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.14/dist/full.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.14/dist/themes.css" rel="stylesheet">
<script src="https://cdn.tailwindcss.com?plugins=typography,forms,aspect-ratio,container-queries"></script>
<script>
  tailwind.config = {
    darkMode: ['class', '[data-theme="dark"]'],
    theme: {
      extend: {
        fontFamily: {
          sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          mono: ['JetBrains Mono', 'ui-monospace', 'SF Mono', 'monospace'],
        },
        colors: {
          brand: {
            50:  '#eef2ff', 100: '#e0e7ff', 200: '#c7d2fe',
            300: '#a5b4fc', 400: '#818cf8', 500: '#6366f1',
            600: '#4f46e5', 700: '#4338ca', 800: '#3730a3', 900: '#312e81',
          },
          // Bridge daisyUI semantic tokens into Tailwind's color system so
          // utilities like bg-base-100 / text-base-content / border-base-300
          // resolve under the Tailwind Play CDN (which is JIT and otherwise
          // unaware of daisyUI's prebuilt classes).
          'base-100':     'hsl(var(--b1) / <alpha-value>)',
          'base-200':     'hsl(var(--b2) / <alpha-value>)',
          'base-300':     'hsl(var(--b3) / <alpha-value>)',
          'base-content': 'hsl(var(--bc) / <alpha-value>)',
          'primary':         'hsl(var(--p)  / <alpha-value>)',
          'primary-content': 'hsl(var(--pc) / <alpha-value>)',
          'secondary':         'hsl(var(--s)  / <alpha-value>)',
          'secondary-content': 'hsl(var(--sc) / <alpha-value>)',
          'accent':         'hsl(var(--a)  / <alpha-value>)',
          'accent-content': 'hsl(var(--ac) / <alpha-value>)',
          'neutral':         'hsl(var(--n)  / <alpha-value>)',
          'neutral-content': 'hsl(var(--nc) / <alpha-value>)',
          'info':    'hsl(var(--in) / <alpha-value>)',
          'success': 'hsl(var(--su) / <alpha-value>)',
          'warning': 'hsl(var(--wa) / <alpha-value>)',
          'error':   'hsl(var(--er) / <alpha-value>)',
        },
        animation: {
          'fade-up': 'fade-up 0.35s ease-out',
          'fade-in': 'fade-in 0.25s ease-out',
        },
        keyframes: {
          'fade-up': { '0%': { opacity: 0, transform: 'translateY(6px)' }, '100%': { opacity: 1, transform: 'translateY(0)' } },
          'fade-in': { '0%': { opacity: 0 }, '100%': { opacity: 1 } },
        },
      }
    },
  }
</script>

<style>
  /* Use plain CSS (not @apply) for things that touch daisyUI semantic
     tokens — under Tailwind Play CDN, @apply runs before our color
     extensions are merged, so @apply bg-base-100 throws. Raw
     hsl(var(--b1)) works because daisyUI defines those vars eagerly. */
  html { font-family: 'Inter', system-ui, sans-serif; font-feature-settings: 'ss01', 'cv11'; -webkit-font-smoothing: antialiased; }
  code, pre, .font-mono { font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', monospace; }
  body { background-color: hsl(var(--b1)); color: hsl(var(--bc)); }

  /* Prose tweaks so generated markdown-ish content looks like a real page */
  .prose :where(h1):not(:where([class~="not-prose"] *)) {
    font-size: 2.25rem; font-weight: 800; letter-spacing: -0.025em; line-height: 1.1;
    margin-top: 0; margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
  }
  .prose :where(h2):not(:where([class~="not-prose"] *)) {
    font-size: 1.5rem; font-weight: 700; letter-spacing: -0.015em;
    margin-top: 3rem; margin-bottom: 1rem; padding-bottom: 0.5rem;
    border-bottom: 1px solid hsl(var(--b3)); position: relative;
    scroll-margin-top: 5rem;
  }
  .prose :where(h2):not(:where([class~="not-prose"] *))::before {
    content: ''; position: absolute; bottom: -1px; left: 0;
    width: 2.5rem; height: 2px;
    background: linear-gradient(90deg, #6366f1, #ec4899);
    border-radius: 2px;
  }
  .prose :where(h3):not(:where([class~="not-prose"] *)) {
    font-size: 1.125rem; font-weight: 600;
    margin-top: 2rem; margin-bottom: 0.75rem;
    scroll-margin-top: 5rem;
  }
  .prose :where(a):not(:where([class~="not-prose"] *)) {
    color: #4f46e5; font-weight: 500; text-decoration: none;
    background-image: linear-gradient(transparent 60%, #e0e7ff 60%);
    background-repeat: no-repeat; background-size: 0 100%;
    transition: background-size 0.2s;
  }
  .prose :where(a):not(:where([class~="not-prose"] *)):hover { background-size: 100% 100%; }
  [data-theme="dark"] .prose :where(a):not(:where([class~="not-prose"] *)) {
    color: #a5b4fc;
    background-image: linear-gradient(transparent 60%, #312e81 60%);
  }
  .prose :where(code):not(:where([class~="not-prose"] *, pre *)) {
    background: hsl(var(--b2)); color: #4f46e5;
    padding: 0.1rem 0.4rem; border-radius: 0.3rem;
    font-size: 0.875em; font-family: 'JetBrains Mono', monospace;
    border: 1px solid hsl(var(--b3));
  }
  [data-theme="dark"] .prose :where(code):not(:where([class~="not-prose"] *, pre *)) { color: #a5b4fc; }
  .prose :where(code):not(:where([class~="not-prose"] *, pre *))::before,
  .prose :where(code):not(:where([class~="not-prose"] *, pre *))::after { content: ''; }
  .prose :where(pre):not(:where([class~="not-prose"] *)) {
    background: hsl(var(--b2)); border: 1px solid hsl(var(--b3));
    border-radius: 0.75rem; padding: 1rem;
    font-size: 0.875rem; overflow-x: auto;
  }
  .prose :where(blockquote):not(:where([class~="not-prose"] *)) {
    border-left: 4px solid #6366f1;
    background: hsl(var(--b2));
    border-top-right-radius: 0.75rem; border-bottom-right-radius: 0.75rem;
    padding: 0.75rem 1rem; font-style: normal; font-weight: normal;
    color: hsl(var(--bc) / 0.85);
  }
  .prose :where(blockquote p):not(:where([class~="not-prose"] *))::before,
  .prose :where(blockquote p):not(:where([class~="not-prose"] *))::after { content: ''; }
  .prose :where(table):not(:where([class~="not-prose"] *)) { font-size: 0.875rem; }
  .prose :where(th):not(:where([class~="not-prose"] *)) { font-weight: 600; }

  /* ── Hero with gradient backdrop ───────────────────────────── */
  .wah-hero {
    position: relative; overflow: hidden;
    border-radius: 1.5rem;
    padding: 3rem 2rem;
    margin-bottom: 2.5rem;
    background:
      radial-gradient(ellipse at top left, rgba(99, 102, 241, 0.18), transparent 55%),
      radial-gradient(ellipse at bottom right, rgba(236, 72, 153, 0.15), transparent 55%),
      linear-gradient(135deg, hsl(var(--b2)) 0%, hsl(var(--b1)) 100%);
    border: 1px solid hsl(var(--b3));
  }
  @media (min-width: 768px) {
    .wah-hero { padding: 4rem 3rem; }
  }
  .wah-hero h1 {
    font-size: 2.25rem; font-weight: 800; letter-spacing: -0.025em;
    margin-bottom: 1rem; line-height: 1.1;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
  }
  @media (min-width: 768px) {
    .wah-hero h1 { font-size: 3rem; }
  }
  .wah-hero .lede {
    font-size: 1.125rem; line-height: 1.65;
    color: hsl(var(--bc) / 0.7);
    max-width: 48rem; margin: 0;
  }
  @media (min-width: 768px) {
    .wah-hero .lede { font-size: 1.25rem; }
  }
  .wah-hero .eyebrow {
    display: inline-block;
    font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: #4f46e5; margin-bottom: 0.75rem;
  }
  [data-theme="dark"] .wah-hero .eyebrow { color: #a5b4fc; }

  /* Gradient-text title (for use outside hero) */
  .grad-text {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
  }
  .grad-bar {
    background: linear-gradient(90deg, #6366f1, #ec4899);
  }

  /* Glossary tooltip (hover) */
  .gloss {
    position: relative; cursor: help; text-decoration: none;
    border-bottom: 1px dashed hsl(var(--p));
  }
  .gloss::after {
    content: attr(data-tip);
    position: absolute; left: 50%; transform: translateX(-50%);
    bottom: calc(100% + 8px);
    background: hsl(var(--b1)); color: hsl(var(--bc));
    border: 1px solid hsl(var(--b3));
    border-radius: 0.5rem; padding: 0.5rem 0.75rem;
    font-size: 0.875rem; line-height: 1.55;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.3);
    pointer-events: none; opacity: 0; visibility: hidden;
    transition: opacity 0.12s, visibility 0.12s;
    width: max-content; max-width: 320px; white-space: normal; z-index: 100;
  }
  .gloss:hover::after, .gloss:focus::after { opacity: 1; visibility: visible; }

  /* Anchor link on hover for h2/h3 */
  .anchor-link {
    opacity: 0; margin-left: 0.5rem;
    color: #6366f1; font-weight: normal;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  h2:hover .anchor-link, h3:hover .anchor-link { opacity: 1; }

  /* Sticky TOC sidebar */
  .toc-link {
    display: block; padding: 0.25rem 0 0.25rem 0.75rem;
    font-size: 0.875rem;
    color: hsl(var(--bc) / 0.6);
    border-left: 2px solid transparent;
    text-decoration: none;
    transition: color 0.12s, border-color 0.12s;
  }
  .toc-link:hover { color: #4f46e5; border-left-color: #a5b4fc; }
  [data-theme="dark"] .toc-link:hover { color: #a5b4fc; }
  .toc-link.toc-h3 { padding-left: 1.5rem; font-size: 0.75rem; }
  .toc-link.active { color: #4f46e5; border-left-color: #6366f1; font-weight: 500; }
  [data-theme="dark"] .toc-link.active { color: #a5b4fc; }

  /* Top reading progress */
  #wah-progress {
    position: fixed; top: 0; left: 0; height: 2px; width: 0;
    z-index: 60;
    background: linear-gradient(90deg, #6366f1, #ec4899);
    transition: width 0.1s;
  }
</style>
{%- block head_extra %}{% endblock %}
</head>

<body class="min-h-screen animate-fade-in">

<div id="wah-progress"></div>

<!-- Top nav (daisyUI navbar) -->
<header class="sticky top-0 z-50 backdrop-blur-md bg-base-100/70 border-b border-base-200">
  <div class="max-w-7xl mx-auto px-4 lg:px-6">
    <div class="navbar min-h-[3.25rem] py-1">
      <div class="flex-1 gap-2">
        <a href="{{ asset_root }}README.html" class="flex items-center gap-2 font-bold text-base no-underline">
          <span class="inline-block w-2.5 h-2.5 rounded-full grad-bar shadow-[0_0_12px_rgba(99,102,241,0.6)]"></span>
          <span class="grad-text">{{ meta.get("title", "wiki") }}</span>
        </a>
      </div>
      <div class="flex-none gap-1">
        {%- for tag in meta.get("tags", []) %}
        <span class="badge badge-ghost badge-sm">{{ tag }}</span>
        {%- endfor %}
        <button id="theme-toggle" class="btn btn-ghost btn-sm btn-circle" title="toggle theme" aria-label="toggle theme">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
      </div>
    </div>
    {# breadcrumb #}
    <nav id="breadcrumb" class="text-xs text-base-content/60 pb-2 -mt-1"></nav>
  </div>
</header>

<!-- Page layout: optional sticky TOC sidebar on the right when content has 3+ h2s -->
<div class="max-w-7xl mx-auto px-4 lg:px-6 py-6 lg:py-10">
  <div id="wah-layout" class="lg:grid lg:grid-cols-[minmax(0,1fr)_220px] lg:gap-10">
    <main id="wah-main" class="min-w-0">
      <!-- wah:meta
{{ meta_yaml }}
-->
      {% block main %}{% endblock %}
    </main>
    <aside id="wah-toc-wrap" class="hidden lg:block">
      <div class="sticky top-20">
        <div class="text-[0.7rem] font-bold uppercase tracking-widest text-base-content/50 mb-3">On this page</div>
        <nav id="wah-toc"></nav>
      </div>
    </aside>
  </div>
</div>

<footer class="border-t border-base-200 mt-16 py-6">
  <div class="max-w-7xl mx-auto px-4 lg:px-6 text-xs text-base-content/50 text-center">
    updated {{ meta.get("updated", "") }}
    &nbsp;·&nbsp; template <span class="font-mono">{{ meta.get("template", "") }}</span>
    &nbsp;·&nbsp; <a href="{{ asset_root }}README.html" class="hover:text-brand-600">index</a>
  </div>
</footer>

<script>
(function () {
  const root = document.documentElement;

  // ── theme (persisted + system pref) ────────────────────────────
  const saved = localStorage.getItem('wah-theme');
  if (saved) { root.setAttribute('data-theme', saved); }
  else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
    root.setAttribute('data-theme', 'dark');
  }
  const tb = document.getElementById('theme-toggle');
  if (tb) tb.addEventListener('click', function () {
    const next = (root.getAttribute('data-theme') || 'light') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('wah-theme', next);
    if (window.mermaid) initMermaid(true);
  });

  // ── breadcrumb ────────────────────────────────────────────────
  const bc = document.getElementById('breadcrumb');
  if (bc) {
    const parts = decodeURIComponent(location.pathname).split('/').filter(Boolean);
    let last = parts[parts.length - 1] || '';
    let here = '', dirParts = parts;
    if (last.endsWith('.html')) { here = last.replace(/\.html$/, ''); dirParts = parts.slice(0, -1); }
    if (last === '' || last === 'README.html') here = '';
    const trail = ['<a href="/" class="hover:text-brand-600">~</a>'];
    let accum = '';
    dirParts.forEach(p => {
      accum += '/' + encodeURIComponent(p);
      trail.push('<a href="' + accum + '/" class="hover:text-brand-600">' + p + '</a>');
    });
    if (here) trail.push('<span class="text-base-content font-medium">' + here + '</span>');
    bc.innerHTML = trail.join('<span class="opacity-40 mx-1.5">/</span>');
  }

  // ── TOC auto-generated from h2/h3 ─────────────────────────────
  const toc = document.getElementById('wah-toc');
  const main = document.getElementById('wah-main');
  if (toc && main) {
    const headings = main.querySelectorAll('h2, h3');
    if (headings.length >= 3) {
      const slug = s => s.toLowerCase().replace(/[^\w一-龥]+/g, '-').replace(/^-+|-+$/g, '');
      const links = [];
      headings.forEach(h => {
        if (!h.id) h.id = slug(h.textContent || '');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        a.className = 'toc-link' + (h.tagName === 'H3' ? ' toc-h3' : '');
        toc.appendChild(a);
        links.push(a);
        // anchor link on heading hover
        const al = document.createElement('a');
        al.href = '#' + h.id; al.className = 'anchor-link'; al.textContent = '#';
        h.appendChild(al);
      });
      // scrollspy
      const io = new IntersectionObserver(entries => {
        entries.forEach(en => {
          const a = toc.querySelector('a[href="#' + en.target.id + '"]');
          if (a && en.isIntersecting) {
            links.forEach(l => l.classList.remove('active'));
            a.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -65% 0px' });
      headings.forEach(h => io.observe(h));
    } else {
      const wrap = document.getElementById('wah-toc-wrap');
      const layout = document.getElementById('wah-layout');
      if (wrap) wrap.remove();
      if (layout) layout.classList.remove('lg:grid', 'lg:grid-cols-[minmax(0,1fr)_220px]', 'lg:gap-10');
    }
  }

  // ── reading progress bar ──────────────────────────────────────
  const pg = document.getElementById('wah-progress');
  if (pg) {
    const onScroll = () => {
      const h = document.documentElement;
      const total = h.scrollHeight - h.clientHeight;
      pg.style.width = total > 0 ? (h.scrollTop / total * 100) + '%' : '0%';
    };
    document.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // ── lazy loaders ──────────────────────────────────────────────
  function loadScript(src, onload) { const s = document.createElement('script'); s.src = src; s.onload = onload; document.head.appendChild(s); }
  function loadCss(href) { const l = document.createElement('link'); l.rel = 'stylesheet'; l.href = href; document.head.appendChild(l); }

  function mermaidTheme() {
    const dark = root.getAttribute('data-theme') === 'dark';
    return {
      theme: 'base',
      themeVariables: {
        fontFamily: 'Inter, system-ui, sans-serif', fontSize: '14px',
        primaryColor: dark ? '#4f46e5' : '#e0e7ff',
        primaryTextColor: dark ? '#ffffff' : '#1e1b4b',
        primaryBorderColor: dark ? '#818cf8' : '#6366f1',
        lineColor: dark ? '#64748b' : '#94a3b8',
        secondaryColor: dark ? '#1e293b' : '#fce7f3',
        secondaryBorderColor: '#ec4899',
        secondaryTextColor: dark ? '#ffffff' : '#831843',
        tertiaryColor: dark ? '#0f172a' : '#ecfeff',
        tertiaryBorderColor: '#06b6d4',
        tertiaryTextColor: dark ? '#ffffff' : '#164e63',
        background: 'transparent',
        mainBkg: dark ? '#4f46e5' : '#e0e7ff',
        nodeBorder: dark ? '#818cf8' : '#6366f1',
        clusterBkg: dark ? '#1e293b' : '#f8fafc',
        clusterBorder: dark ? '#475569' : '#cbd5e1',
        edgeLabelBackground: dark ? '#0f1117' : '#ffffff',
      },
      securityLevel: 'loose', startOnLoad: false,
    };
  }
  function initMermaid(force) {
    if (!window.mermaid) return;
    window.mermaid.initialize(mermaidTheme());
    document.querySelectorAll('.mermaid').forEach(el => {
      if (force) { el.removeAttribute('data-processed'); el.innerHTML = el.dataset.src || el.textContent; }
      else { el.dataset.src = el.textContent; }
    });
    window.mermaid.run();
  }
  if (document.querySelector('pre.mermaid, code.mermaid, .mermaid')) {
    loadScript('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js', () => initMermaid(false));
  }

  // highlight.js
  if (document.querySelector('pre code')) {
    const dark = root.getAttribute('data-theme') === 'dark';
    loadCss(dark
      ? 'https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/atom-one-dark.min.css'
      : 'https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/github.min.css');
    loadScript('https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js', () => {
      window.hljs && window.hljs.highlightAll();
    });
  }

  // KaTeX
  const hasMath = /(\$[^$\n]+\$|\$\$[\s\S]+?\$\$)/.test(document.body.textContent || '');
  if (hasMath || document.querySelector('.math')) {
    loadCss('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css');
    loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js', () => {
      loadScript('https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js', () => {
        window.renderMathInElement(document.body, {
          delimiters: [
            { left: '$$', right: '$$', display: true },
            { left: '$',  right: '$',  display: false },
            { left: '\\(', right: '\\)', display: false },
            { left: '\\[', right: '\\]', display: true },
          ],
          throwOnError: false,
        });
      });
    });
  }

  // Chart.js
  if (document.querySelector('canvas[data-chart]')) {
    loadScript('https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js', () => {
      window.Chart.defaults.font.family = "Inter, system-ui, sans-serif";
      window.Chart.defaults.color = (root.getAttribute('data-theme') === 'dark') ? '#94a3b8' : '#64748b';
      document.querySelectorAll('canvas[data-chart]').forEach(canvas => {
        try { new window.Chart(canvas, JSON.parse(canvas.dataset.chart)); }
        catch (e) { console.error('chart parse', e, canvas); }
      });
    });
  }

  // Lucide
  if (document.querySelector('[data-lucide]')) {
    loadScript('https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js', () => {
      window.lucide && window.lucide.createIcons();
    });
  }

  // Lightbox
  if (document.querySelector('.zoomable')) {
    loadCss('https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css');
    loadScript('https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js', () => {
      window.GLightbox({ selector: '.zoomable' });
    });
  }
})();
</script>

</body>
</html>
