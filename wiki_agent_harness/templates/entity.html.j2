{#- description: named thing (person, project, product, dataset, paper). Slots: summary, attributes, description, related_notes. -#}
{% extends "base.html.j2" %}

{% block main %}
<article>
  <h1>{{ meta.get("title", "Untitled") }}</h1>

  <p class="lede">
    <!-- wah:slot id="summary" -->
    <!-- /wah:slot -->
  </p>

  <table>
    <tbody>
      <!-- wah:slot id="attributes" -->
      <!-- fill rows like: <tr><th scope="row">Role</th><td>...</td></tr> -->
      <!-- /wah:slot -->
    </tbody>
  </table>

  <section>
    <h2>Description</h2>
    <!-- wah:slot id="description" -->
    <!-- /wah:slot -->
  </section>

  <section>
    <h2>Notes</h2>
    <!-- wah:slot id="related_notes" -->
    <!-- /wah:slot -->
  </section>

  {%- if meta.get("related") %}
  <h2 class="section-label">Related</h2>
  <div class="card-grid">
    {%- for r in meta.get("related", []) %}
    <a href="{{ r.href }}" class="card"><h3>{{ r.title }}</h3></a>
    {%- endfor %}
  </div>
  {%- endif %}
</article>
{% endblock %}
